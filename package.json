{
  "name": "@linz/action-otel",
  "version": "1.0.0",
  "description": "Exports a TRACEPARENT environment variable",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "prebuild": "rm -rf dist",
    "test": "node --test src/index.test.ts",
    "lint": "oxlint . --type-aware",
    "format": "oxfmt .",
    "check": "npm run lint && oxfmt . --check"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.49.1",
    "@opentelemetry/resources": "^1.22.0",
    "@opentelemetry/sdk-trace-base": "^1.22.0",
    "@opentelemetry/semantic-conventions": "^1.22.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.3.3"
  }
}
